//! Comparaison parallèle de plusieurs moteurs UCI sur la même position.
//!
//! [`EvalComparator`] permet de soumettre une position à N moteurs
//! simultanément via des threads OS, puis de collecter leurs résultats.
//!
//! Chaque moteur tourne dans son propre processus ; les threads sont
//! indépendants et ne partagent aucun état.
//!
//! ## Stratégie de parallélisme
//!
//! À chaque appel à [`EvalComparator::compare`] :
//!
//! 1. Les moteurs sont extraits du comparateur (`mem::take`).
//! 2. Chaque moteur est déplacé (`move`) dans un thread dédié.
//! 3. Les threads sont rejoints dans l'ordre de lancement.
//! 4. Les moteurs sont réinsérés dans le comparateur — il est donc
//!    réutilisable après l'appel.
//!
//! Si un thread panique (cas exceptionnel), le moteur correspondant
//! est perdu mais les autres restent disponibles.

use std::thread;

use uci::{
    engine::{AnalysisResult, EngineError, EnginePosition, UciEngine},
    protocol::GoLimits,
};

use crate::config::{ConfigError, EngineConfig};

// ---------------------------------------------------------------------------
// Erreurs
// ---------------------------------------------------------------------------

/// Erreur du comparateur.
#[derive(Debug)]
pub enum ComparatorError {
    /// Un moteur avec cet identifiant est déjà enregistré.
    DuplicateId(String),
    /// Erreur de connexion ou de communication avec le moteur.
    Engine(EngineError),
    /// La configuration du moteur est invalide.
    Config(ConfigError),
}

impl std::fmt::Display for ComparatorError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            Self::DuplicateId(id) =>
                write!(f, "Identifiant déjà utilisé : '{id}'"),
            Self::Engine(e) =>
                write!(f, "Erreur moteur : {e}"),
            Self::Config(e) =>
                write!(f, "Configuration invalide : {e}"),
        }
    }
}

impl std::error::Error for ComparatorError {}

impl From<EngineError> for ComparatorError {
    fn from(e: EngineError) -> Self { Self::Engine(e) }
}

impl From<ConfigError> for ComparatorError {
    fn from(e: ConfigError) -> Self { Self::Config(e) }
}

// ---------------------------------------------------------------------------
// CompareResult
// ---------------------------------------------------------------------------

/// Résultat d'un moteur dans une comparaison.
#[derive(Debug)]
pub struct CompareResult {
    /// Identifiant du moteur (tel que fourni à [`EvalComparator::add`]).
    pub engine_id: String,
    /// Résultat de l'analyse (ou erreur si le moteur a échoué).
    pub result:    Result<AnalysisResult, EngineError>,
}

impl CompareResult {
    /// Retourne `true` si l'analyse s'est terminée sans erreur.
    #[must_use]
    pub fn is_ok(&self) -> bool {
        self.result.is_ok()
    }

    /// Retourne le meilleur coup (UCI) si l'analyse a réussi.
    #[must_use]
    pub fn best_move(&self) -> Option<&str> {
        self.result.as_ref().ok().map(|r| r.best_move.as_str())
    }

    /// Retourne l'évaluation centipawn de la variation principale, si disponible.
    #[must_use]
    pub fn score_cp(&self) -> Option<i32> {
        use uci::parser::UciScore;
        self.result.as_ref().ok().and_then(|r| {
            r.principal_variation().and_then(|pv| {
                pv.score.as_ref().and_then(|s| {
                    if let UciScore::Centipawns(cp) = s { Some(*cp) } else { None }
                })
            })
        })
    }
}

// ---------------------------------------------------------------------------
// EvalComparator
// ---------------------------------------------------------------------------

/// Comparateur multi-moteurs : analyse la même position en parallèle.
///
/// Contrairement à [`EnginePool`](crate::pool::EnginePool), le comparateur
/// est conçu pour lancer des analyses simultanées et comparer les résultats.
///
/// Les moteurs sont ajoutés via [`add`](EvalComparator::add) puis consultés
/// via [`compare`](EvalComparator::compare).
#[derive(Default)]
pub struct EvalComparator {
    /// Moteurs actifs, chacun identifié par un nom libre.
    engines: Vec<(String, UciEngine)>,
}

impl std::fmt::Debug for EvalComparator {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        f.debug_struct("EvalComparator")
            .field("engine_count", &self.engines.len())
            .field("ids", &self.engine_ids())
            .finish()
    }
}

impl EvalComparator {
    /// Crée un comparateur vide.
    #[must_use]
    pub fn new() -> Self {
        Self::default()
    }

    // -----------------------------------------------------------------------
    // Gestion des moteurs
    // -----------------------------------------------------------------------

    /// Connecte un moteur et l'enregistre sous l'identifiant `id`.
    ///
    /// # Errors
    ///
    /// - [`ComparatorError::DuplicateId`] si `id` est déjà présent.
    /// - [`ComparatorError::Config`] si le binaire est invalide.
    /// - [`ComparatorError::Engine`] si la connexion ou le handshake échoue.
    pub fn add(
        &mut self,
        id:     impl Into<String>,
        config: EngineConfig,
    ) -> Result<(), ComparatorError> {
        let id = id.into();
        if self.engines.iter().any(|(eid, _)| eid == &id) {
            return Err(ComparatorError::DuplicateId(id));
        }
        config.validate()?;
        let path_str = config.path.to_str().unwrap_or_default();
        let mut engine = UciEngine::connect_with_timeout(path_str, config.init_timeout)?;
        for (name, value) in &config.options {
            engine.set_option(name, Some(value.as_str()))?;
        }
        self.engines.push((id, engine));
        Ok(())
    }

    // -----------------------------------------------------------------------
    // Accesseurs
    // -----------------------------------------------------------------------

    /// Nombre de moteurs enregistrés.
    #[must_use]
    pub fn len(&self) -> usize {
        self.engines.len()
    }

    /// Retourne `true` si aucun moteur n'est enregistré.
    #[must_use]
    pub fn is_empty(&self) -> bool {
        self.engines.is_empty()
    }

    /// Liste des identifiants, triée alphabétiquement.
    #[must_use]
    pub fn engine_ids(&self) -> Vec<&str> {
        let mut ids: Vec<&str> = self.engines.iter().map(|(id, _)| id.as_str()).collect();
        ids.sort_unstable();
        ids
    }

    // -----------------------------------------------------------------------
    // Analyse parallèle
    // -----------------------------------------------------------------------

    /// Analyse `position` avec `limits` sur tous les moteurs en parallèle.
    ///
    /// Retourne un vecteur de [`CompareResult`] dans le même ordre que
    /// les moteurs ont été ajoutés.
    ///
    /// Les moteurs sont réinsérés dans le comparateur après l'analyse ;
    /// [`compare`](Self::compare) peut donc être appelé plusieurs fois.
    ///
    /// Si un thread panique (cas exceptionnel), le moteur correspondant
    /// est perdu mais tous les autres restent disponibles.
    pub fn compare(
        &mut self,
        position: &EnginePosition,
        limits:   &GoLimits,
    ) -> Vec<CompareResult> {
        // Extraire les moteurs pour en obtenir la propriété (ownership).
        let engines = std::mem::take(&mut self.engines);

        // Lancer un thread par moteur.
        let handles: Vec<thread::JoinHandle<(String, UciEngine, Result<AnalysisResult, EngineError>)>> =
            engines
                .into_iter()
                .map(|(id, mut engine)| {
                    let pos = position.clone();
                    let lim = limits.clone();
                    thread::spawn(move || {
                        let result = engine.analyze(&pos, &lim);
                        (id, engine, result)
                    })
                })
                .collect();

        // Rejoindre les threads et reconstruire self.engines.
        let mut results = Vec::with_capacity(handles.len());
        for handle in handles {
            match handle.join() {
                Ok((id, engine, result)) => {
                    results.push(CompareResult { engine_id: id.clone(), result });
                    self.engines.push((id, engine));
                }
                Err(_) => {
                    // Thread en panique : le moteur est perdu.
                    // Les autres moteurs restent disponibles.
                }
            }
        }
        results
    }

    /// Commodité : retourne uniquement les meilleurs coups par moteur.
    ///
    /// Chaque paire est `(engine_id, best_move_uci)`. Les moteurs ayant
    /// retourné une erreur sont omis.
    pub fn best_moves(
        &mut self,
        position: &EnginePosition,
        limits:   &GoLimits,
    ) -> Vec<(String, String)> {
        self.compare(position, limits)
            .into_iter()
            .filter_map(|cr| {
                cr.result.ok().map(|r| (cr.engine_id, r.best_move))
            })
            .collect()
    }
}

impl Drop for EvalComparator {
    /// Ferme tous les moteurs en parallèle (un thread par moteur, comme
    /// [`crate::pool::EnginePool::quit_all`]) : évite jusqu'à N×3 s de
    /// blocage séquentiel si plusieurs moteurs sont lents à répondre à
    /// `quit` (audit perf 02/07/2026, point 3).
    fn drop(&mut self) {
        let engines = std::mem::take(&mut self.engines);
        let handles: Vec<_> = engines
            .into_iter()
            .map(|(_, engine)| std::thread::spawn(move || engine.quit()))
            .collect();
        for h in handles {
            let _ = h.join();
        }
    }
}

// ---------------------------------------------------------------------------
// Tests
