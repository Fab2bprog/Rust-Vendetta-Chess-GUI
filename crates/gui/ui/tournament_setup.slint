// ui/tournament_setup.slint
// Configuration wizard for a tournament between UCI engines.
//
// Step 0: Format (Round Robin / Gauntlet) + games per pair
// Step 1: Selection of participating engines (≥ 2, checkboxes)
// Step 2: Time control (movetime or Fischer/PerGame clock) + recap
//
// Final callback:
//   start-tournament(kind, gpp, engine-mask, tc-idx)
//     kind        : "roundrobin" | "gauntlet"
//     gpp         : 1 | 2  (games per pair)
//     engine-mask : bitmask (bit i = engine i selected in available-engines)
//     tc-idx      : 0-3 = movetime (1/3/5/10 s), 4-10 = clocks (Bullet…Classical)

import { Theme }       from "theme.slint";
import { SavedEngine } from "types.slint";
import { Tr }          from "translations.slint";

// ── Format selection card ─────────────────────────────────────────────
component FormatCard inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <string> desc;
    in property <bool>   selected;
    callback clicked;

    border-radius: 10px;
    border-width: 2px;
    border-color: selected ? Theme.blue : Theme.surface1;
    background:   selected ? Theme.blue.with-alpha(0.13) : (ta.has-hover ? Theme.hover : Theme.surface0);
    animate background, border-color { duration: 130ms; }

    VerticalLayout {
        alignment: center; spacing: 5px; padding: 12px;
        Text { text: icon;  font-size: 20px; color: Theme.text; horizontal-alignment: center; }
        Text { text: label; color: selected ? Theme.blue : Theme.text; font-size: 12px; font-weight: 700; horizontal-alignment: center; }
        Text { text: desc;  color: Theme.overlay0; font-size: 9px; horizontal-alignment: center; wrap: word-wrap; }
    }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// ── Generic selection button (gpp, movetime) ────────────────────────────
component SelBtn inherits Rectangle {
    in property <string> label;
    in property <bool>   selected;
    callback clicked;

    height: 36px;
    border-radius: 6px;
    border-width: selected ? 0px : 1px;
    border-color: Theme.surface1;
    background:   selected ? Theme.blue : (ta.has-hover ? Theme.hover : Theme.surface0);
    animate background { duration: 100ms; }

    Text {
        width: parent.width; height: parent.height;
        text: label;
        color: selected ? #ffffff : Theme.text;
        font-size: 11px; font-weight: selected ? 700 : 400;
        horizontal-alignment: center; vertical-alignment: center;
    }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// ── Main wizard ──────────────────────────────────────────────────────────
export component TournamentSetupWizard inherits Rectangle {

    // ── Input properties ───────────────────────────────────────────────
    /// List of available UCI engines (from prefs).
    in property <[SavedEngine]> available-engines;

    // ── Callbacks ─────────────────────────────────────────────────────────
    /// Launches the tournament with the chosen parameters.
    /// kind        : "roundrobin" | "gauntlet"
    /// gpp         : games per pair (1 or 2)
    /// engine-mask : bitmask — bit i = engine i selected
    /// tc-idx      : time control index (0-3 movetime, 4-10 clock)
    callback start-tournament(string, int, int, int);
    callback cancel();

    // ── Internal wizard state ───────────────────────────────────────────────
    private property <int>    step:   0;
    private property <string> t-kind: "roundrobin";
    private property <int>    gpp:    1;
    private property <int>    tc-idx: 6;  // Blitz 3+2 by default

    // Engine selection — one bool property per slot (max 8).
    // Direct approach: Slint correctly tracks sel0..sel7 as reactive
    // dependencies, unlike bitmasks via array/function in a for loop.
    private property <bool> sel0: false;
    private property <bool> sel1: false;
    private property <bool> sel2: false;
    private property <bool> sel3: false;
    private property <bool> sel4: false;
    private property <bool> sel5: false;
    private property <bool> sel6: false;
    private property <bool> sel7: false;

    // Number of selected engines (reactive on sel0..sel7).
    private property <int> sel-count:
        (sel0 ? 1 : 0) + (sel1 ? 1 : 0) + (sel2 ? 1 : 0) + (sel3 ? 1 : 0)
      + (sel4 ? 1 : 0) + (sel5 ? 1 : 0) + (sel6 ? 1 : 0) + (sel7 ? 1 : 0);

    // ── Semi-transparent background ─────────────────────────────────────────────
    background: Theme.crust.with-alpha(0.82);

    // ── Centered panel ────────────────────────────────────────────────────
    Rectangle {
        width:  560px;
        height: 500px;
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        background:    Theme.base;
        border-radius: 14px;
        drop-shadow-blur:     28px;
        drop-shadow-offset-y: 8px;
        drop-shadow-color:    Theme.shadow;

        VerticalLayout {
            padding: 24px; spacing: 0px;

            // ── Header: title + step dots ──────────────────────
            HorizontalLayout {
                spacing: 8px; height: 28px;

                Text {
                    text: "⚔  " + Tr.tournament-title;
                    color: Theme.text; font-size: 15px; font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                // Dots 0–1–2
                HorizontalLayout {
                    spacing: 6px; alignment: center;
                    for dot-idx in [0, 1, 2]: Rectangle {
                        width: 8px; height: 8px; border-radius: 4px;
                        background: root.step == dot-idx ? Theme.blue : Theme.surface1;
                        animate background { duration: 150ms; }
                    }
                }
            }

            // Step subtitle
            Text {
                text: root.step == 0 ? Tr.tournament-step1-title
                    : root.step == 1 ? Tr.tournament-step2-title
                    :                  Tr.tournament-step3-title;
                color: Theme.overlay0; font-size: 10px;
            }

            // Separator (spacers since Slint has no margin-top/bottom)
            Rectangle { height: 14px; }
            Rectangle { height: 1px; background: Theme.surface0; }
            Rectangle { height: 14px; }

            // ── STEP 0: Format + gpp ────────────────────────────────────
            if root.step == 0: VerticalLayout {
                vertical-stretch: 1; spacing: 14px; alignment: start;

                Text {
                    text: Tr.tournament-format-title;
                    color: Theme.overlay0; font-size: 9px; font-weight: 700;
                    letter-spacing: 0.8px;
                }

                HorizontalLayout {
                    spacing: 12px; height: 120px;
                    FormatCard {
                        horizontal-stretch: 1;
                        icon: "♟";
                        label: Tr.tournament-format-roundrobin-label;
                        desc: Tr.tournament-format-roundrobin-desc;
                        selected: root.t-kind == "roundrobin";
                        clicked => { root.t-kind = "roundrobin"; }
                    }
                    FormatCard {
                        horizontal-stretch: 1;
                        icon: "⚔";
                        label: Tr.tournament-format-gauntlet-label;
                        desc: Tr.tournament-format-gauntlet-desc;
                        selected: root.t-kind == "gauntlet";
                        clicked => { root.t-kind = "gauntlet"; }
                    }
                }

                Rectangle { height: 1px; background: Theme.surface0; }

                Text {
                    text: Tr.tournament-games-per-pair-title;
                    color: Theme.overlay0; font-size: 9px; font-weight: 700;
                    letter-spacing: 0.8px;
                }

                HorizontalLayout {
                    spacing: 8px; height: 36px;
                    SelBtn {
                        horizontal-stretch: 1;
                        label: Tr.tournament-gpp-one;
                        selected: root.gpp == 1;
                        clicked => { root.gpp = 1; }
                    }
                    SelBtn {
                        horizontal-stretch: 1;
                        label: Tr.tournament-gpp-two;
                        selected: root.gpp == 2;
                        clicked => { root.gpp = 2; }
                    }
                }
            }

            // ── STEP 1: Engine selection ───────────────────────────────
            // Implementation without a for loop: each row directly references
            // sel0..sel7, guaranteeing Slint reactivity (the for loop + bitmask
            // did not correctly propagate state changes).
            if root.step == 1: VerticalLayout {
                vertical-stretch: 1; spacing: 8px; alignment: start;

                // Header + counter
                HorizontalLayout {
                    spacing: 8px; height: 18px; alignment: start;
                    Text {
                        text: Tr.tournament-engines-title;
                        color: Theme.overlay0; font-size: 9px; font-weight: 700;
                        letter-spacing: 0.8px; vertical-alignment: center;
                    }
                    Text {
                        text: root.sel-count >= 2
                            ? "(" + root.sel-count + " " + Tr.tournament-engines-selected-suffix + ")"
                            : "(" + Tr.tournament-engines-select-hint + ")";
                        color: root.sel-count >= 2 ? Theme.blue : Theme.peach;
                        font-size: 9px; vertical-alignment: center;
                    }
                }

                // Message if not enough engines
                if root.available-engines.length < 2: Rectangle {
                    height: 60px; background: Theme.mantle; border-radius: 8px;
                    Text {
                        width: parent.width - 24px; x: 12px;
                        y: (parent.height - self.height) / 2;
                        text: Tr.tournament-need-2-engines;
                        color: Theme.overlay0; font-size: 10px;
                        wrap: word-wrap; horizontal-alignment: center;
                    }
                }

                // Engine rows — enclosing Rectangle with a full-size TouchArea.
                // The TouchArea is a sibling of the HorizontalLayout (not inside it) to cover
                // the row's full height and correctly receive clicks.
                if root.available-engines.length > 0: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta0.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel0 ? Theme.blue : Theme.overlay0; background: root.sel0 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel0: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[0].name; color: root.sel0 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel0 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                        if root.t-kind == "gauntlet" && root.sel0: Text { text: Tr.tournament-challenger-label; color: Theme.peach; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                    }
                    ta0 := TouchArea { mouse-cursor: pointer; clicked => { root.sel0 = !root.sel0; } }
                }
                if root.available-engines.length > 1: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta1.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel1 ? Theme.blue : Theme.overlay0; background: root.sel1 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel1: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[1].name; color: root.sel1 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel1 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                        if root.t-kind == "gauntlet" && !root.sel0 && root.sel1: Text { text: Tr.tournament-challenger-label; color: Theme.peach; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                    }
                    ta1 := TouchArea { mouse-cursor: pointer; clicked => { root.sel1 = !root.sel1; } }
                }
                if root.available-engines.length > 2: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta2.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel2 ? Theme.blue : Theme.overlay0; background: root.sel2 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel2: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[2].name; color: root.sel2 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel2 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                    }
                    ta2 := TouchArea { mouse-cursor: pointer; clicked => { root.sel2 = !root.sel2; } }
                }
                if root.available-engines.length > 3: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta3.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel3 ? Theme.blue : Theme.overlay0; background: root.sel3 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel3: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[3].name; color: root.sel3 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel3 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                    }
                    ta3 := TouchArea { mouse-cursor: pointer; clicked => { root.sel3 = !root.sel3; } }
                }
                if root.available-engines.length > 4: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta4.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel4 ? Theme.blue : Theme.overlay0; background: root.sel4 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel4: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[4].name; color: root.sel4 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel4 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                    }
                    ta4 := TouchArea { mouse-cursor: pointer; clicked => { root.sel4 = !root.sel4; } }
                }
                if root.available-engines.length > 5: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta5.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel5 ? Theme.blue : Theme.overlay0; background: root.sel5 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel5: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[5].name; color: root.sel5 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel5 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                    }
                    ta5 := TouchArea { mouse-cursor: pointer; clicked => { root.sel5 = !root.sel5; } }
                }
                if root.available-engines.length > 6: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta6.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel6 ? Theme.blue : Theme.overlay0; background: root.sel6 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel6: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[6].name; color: root.sel6 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel6 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                    }
                    ta6 := TouchArea { mouse-cursor: pointer; clicked => { root.sel6 = !root.sel6; } }
                }
                if root.available-engines.length > 7: Rectangle {
                    height: 32px; border-radius: 6px;
                    background: ta7.has-hover ? Theme.hover : transparent;
                    animate background { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 10px;
                        Rectangle { width: 18px; height: 18px; y: 7px; border-radius: 4px; border-width: 1.5px; border-color: root.sel7 ? Theme.blue : Theme.overlay0; background: root.sel7 ? Theme.blue : transparent; animate background, border-color { duration: 100ms; }
                            if root.sel7: Text { width: parent.width; height: parent.height; text: "✓"; color: #ffffff; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        Text { text: root.available-engines[7].name; color: root.sel7 ? Theme.blue : Theme.text; font-size: 12px; font-weight: root.sel7 ? 700 : 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
                    }
                    ta7 := TouchArea { mouse-cursor: pointer; clicked => { root.sel7 = !root.sel7; } }
                }

                Rectangle { vertical-stretch: 1; }

                // Gauntlet note
                if root.t-kind == "gauntlet": Text {
                    text: "ⓘ  " + Tr.tournament-gauntlet-note;
                    color: Theme.overlay0; font-size: 9px; wrap: word-wrap;
                }
            }

            // ── STEP 2: Time control ─────────────────────────────────────────
            if root.step == 2: VerticalLayout {
                vertical-stretch: 1; spacing: 10px; alignment: start;

                // ── Quick test (fixed movetime) ────────────────────────────
                Text {
                    text: Tr.tournament-quick-test-title;
                    color: Theme.overlay0; font-size: 9px; font-weight: 700;
                    letter-spacing: 0.8px;
                }
                HorizontalLayout {
                    spacing: 8px; height: 36px;
                    SelBtn { horizontal-stretch: 1; label: "1 s/coup";  selected: root.tc-idx == 0; clicked => { root.tc-idx = 0; } }
                    SelBtn { horizontal-stretch: 1; label: "3 s/coup";  selected: root.tc-idx == 1; clicked => { root.tc-idx = 1; } }
                    SelBtn { horizontal-stretch: 1; label: "5 s/coup";  selected: root.tc-idx == 2; clicked => { root.tc-idx = 2; } }
                    SelBtn { horizontal-stretch: 1; label: "10 s/coup"; selected: root.tc-idx == 3; clicked => { root.tc-idx = 3; } }
                }

                // Separator
                Rectangle { height: 1px; background: Theme.surface0; }

                // ── Timed time controls ─────────────────────────────────
                Text {
                    text: Tr.tournament-timed-cadences-title;
                    color: Theme.overlay0; font-size: 9px; font-weight: 700;
                    letter-spacing: 0.8px;
                }
                HorizontalLayout {
                    spacing: 8px; height: 36px;
                    SelBtn { horizontal-stretch: 1; label: "Bullet 1+0";  selected: root.tc-idx == 4; clicked => { root.tc-idx = 4; } }
                    SelBtn { horizontal-stretch: 1; label: "Bullet 2+1";  selected: root.tc-idx == 5; clicked => { root.tc-idx = 5; } }
                    SelBtn { horizontal-stretch: 1; label: "Blitz 3+2";   selected: root.tc-idx == 6; clicked => { root.tc-idx = 6; } }
                    SelBtn { horizontal-stretch: 1; label: "Blitz 5+0";   selected: root.tc-idx == 7; clicked => { root.tc-idx = 7; } }
                }
                HorizontalLayout {
                    spacing: 8px; height: 36px;
                    SelBtn { horizontal-stretch: 1; label: "Rapide 10+5";   selected: root.tc-idx == 8;  clicked => { root.tc-idx = 8;  } }
                    SelBtn { horizontal-stretch: 1; label: "Rapide 15+10";  selected: root.tc-idx == 9;  clicked => { root.tc-idx = 9;  } }
                    SelBtn { horizontal-stretch: 1; label: "Classic 90+30"; selected: root.tc-idx == 10; clicked => { root.tc-idx = 10; } }
                    Rectangle { horizontal-stretch: 1; }
                }

                Rectangle { vertical-stretch: 1; }

                // ── Recap before starting ──────────────────────────
                Rectangle {
                    height: 90px;
                    background: Theme.surface0;
                    border-radius: 10px;
                    VerticalLayout {
                        padding: 12px; spacing: 5px; alignment: center;
                        Text {
                            text: Tr.tournament-recap-title;
                            color: Theme.overlay0; font-size: 9px; font-weight: 700;
                            letter-spacing: 0.5px; horizontal-alignment: center;
                        }
                        Text {
                            text: (root.t-kind == "roundrobin" ? Tr.tournament-format-roundrobin-label : Tr.tournament-format-gauntlet-label)
                                + "  ·  " + root.sel-count + " " + Tr.tournament-recap-engines-suffix
                                + "  ·  " + root.gpp + " " + Tr.tournament-recap-games-per-pair-suffix;
                            color: Theme.text; font-size: 12px; font-weight: 700;
                            horizontal-alignment: center;
                        }
                        Text {
                            text:
                                root.tc-idx == 0  ? "1 s / coup (movetime)" :
                                root.tc-idx == 1  ? "3 s / coup (movetime)" :
                                root.tc-idx == 2  ? "5 s / coup (movetime)" :
                                root.tc-idx == 3  ? "10 s / coup (movetime)" :
                                root.tc-idx == 4  ? "Bullet 1+0" :
                                root.tc-idx == 5  ? "Bullet 2+1" :
                                root.tc-idx == 6  ? "Blitz 3+2" :
                                root.tc-idx == 7  ? "Blitz 5+0" :
                                root.tc-idx == 8  ? "Rapide 10+5" :
                                root.tc-idx == 9  ? "Rapide 15+10" :
                                                    "Classique 90+30";
                            color: Theme.subtext0; font-size: 10px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }

            // Separator before navigation
            Rectangle { height: 14px; }
            Rectangle { height: 1px; background: Theme.surface0; }
            Rectangle { height: 12px; }

            // ── Navigation ────────────────────────────────────────────────
            HorizontalLayout {
                height: 36px; spacing: 8px;

                // Cancel (always visible)
                Rectangle {
                    width: 88px;
                    border-radius: 6px;
                    background: ta-cancel.has-hover ? Theme.hover : Theme.surface0;
                    Text {
                        width: parent.width; height: parent.height;
                        text: Tr.btn-cancel;
                        color: Theme.overlay0; font-size: 11px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                    ta-cancel := TouchArea { mouse-cursor: pointer; clicked => { root.cancel(); } }
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // Previous (steps 1 and 2)
                if root.step > 0: Rectangle {
                    width: 104px;
                    border-radius: 6px;
                    background: ta-prev.has-hover ? Theme.hover : Theme.surface0;
                    Text {
                        width: parent.width; height: parent.height;
                        text: "← " + Tr.wizard-nav-previous;
                        color: Theme.text; font-size: 11px;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                    ta-prev := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.step = root.step - 1; }
                    }
                }

                // Next / Start
                Rectangle {
                    width: 124px;
                    border-radius: 6px;
                    property <bool> can-go: root.step == 0
                        || (root.step == 1 && root.sel-count >= 2)
                        || root.step == 2;
                    background: can-go
                        ? (ta-next.has-hover ? Theme.blue : Theme.blue.with-alpha(0.84))
                        : Theme.surface1;
                    animate background { duration: 100ms; }

                    Text {
                        width: parent.width; height: parent.height;
                        text: root.step == 2 ? ("⚔  " + Tr.btn-start) : (Tr.wizard-btn-next + " →");
                        color: can-go ? #ffffff : Theme.overlay0;
                        font-size: 11px; font-weight: 700;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                    ta-next := TouchArea {
                        mouse-cursor: parent.can-go ? pointer : default;
                        enabled: parent.can-go;
                        clicked => {
                            if root.step < 2 {
                                root.step = root.step + 1;
                            } else {
                                root.start-tournament(
                                    root.t-kind,
                                    root.gpp,
                                    (root.sel0 ? 1   : 0) + (root.sel1 ? 2   : 0)
                                  + (root.sel2 ? 4   : 0) + (root.sel3 ? 8   : 0)
                                  + (root.sel4 ? 16  : 0) + (root.sel5 ? 32  : 0)
                                  + (root.sel6 ? 64  : 0) + (root.sel7 ? 128 : 0),
                                    root.tc-idx
                                );
                            }
                        }
                    }
                }
            }
        }
    }
}
