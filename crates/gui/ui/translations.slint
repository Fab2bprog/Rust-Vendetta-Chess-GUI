    in-out property <string> board-black;
    in-out property <string> board-turn-white;
    in-out property <string> board-turn-black;
    in-out property <string> board-check;
    in-out property <string> board-checkmate;
    in-out property <string> board-stalemate;
    in-out property <string> board-draw;

    // ── Game results ───────────────────────────────────────────────────
    in-out property <string> game-result-white-wins;
    in-out property <string> game-result-black-wins;
    in-out property <string> game-result-draw;
    in-out property <string> game-result-ongoing;

    // ── Analysis ───────────────────────────────────────────────────────────────
    in-out property <string> analysis-depth;
