// Slint global exposing all the translated strings.
//
// Updated from Rust via `i18n_bridge::apply_translations()` on
// startup and on every language change. The properties are
// reactive: any Slint binding that references them updates
// automatically as soon as they change.
//
// Naming convention: i18n key `"a.b_c"` → Slint property `a-b-c`.

export global Tr {

    // ── Application ──────────────────────────────────────────────────────────
    in-out property <string> app-name;
    in-out property <string> app-version;

    // ── Menus ─────────────────────────────────────────────────────────────────
    in-out property <string> menu-file;
    in-out property <string> menu-file-new-game;
    in-out property <string> menu-file-open-pgn;
    in-out property <string> menu-file-save-pgn;
    in-out property <string> menu-file-quit;

    in-out property <string> menu-edit;
    in-out property <string> menu-edit-undo;
    in-out property <string> menu-edit-copy-pgn;
    in-out property <string> menu-edit-copy-fen;

    in-out property <string> menu-view;
    in-out property <string> menu-view-rotate-board;
    in-out property <string> menu-view-coordinates;
    in-out property <string> menu-view-legal-moves;

    in-out property <string> menu-engine;
    in-out property <string> menu-engine-configure;
    in-out property <string> menu-engine-analyze;
    in-out property <string> menu-engine-stop;
    in-out property <string> menu-engine-multi-pv;

    in-out property <string> menu-tournament;
