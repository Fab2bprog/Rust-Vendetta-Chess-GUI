    in-out property <string> engine-thinking;
    in-out property <string> engine-stopped;
    in-out property <string> engine-no-engine;

    // ── LAN network ────────────────────────────────────────────────────────────
    in-out property <string> network-host;
    in-out property <string> network-join;
    in-out property <string> network-connecting;
    in-out property <string> network-connected;
    in-out property <string> network-disconnected;
    in-out property <string> network-waiting;
    in-out property <string> network-your-turn;
    in-out property <string> network-opponent-turn;

    // ── Promotion ─────────────────────────────────────────────────────────────
